{
    "$schema": "https://schema.tauri.app/config/2",
    "productName": "rw-tracker-map",
    "version": "0.1.0",
    "identifier": "com.zohnannor.rw-tracker-map",
    "build": {
        "beforeDevCommand": "yarn dev",
        "devUrl": "http://localhost:1420",
        "beforeBuildCommand": "yarn build",
        "frontendDist": "../dist"
    },
    "app": {
        "windows": [
            {
                "title": "rw-tracker-map",
                "width": 800,
                "height": 600
            }
        ],
        "security": {
            "csp": null
        }
    },
    "bundle": {
        "active": true,
        "targets": [
            "deb",
            "rpm",
            "msi",
            "app",
            "nsis"
        ]
    }
}
